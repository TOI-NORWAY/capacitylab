{
  "name": "capacitylab-cpu",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "../.."
  },
  "runArgs": [
    "--name",
    "${localWorkspaceFolderBasename}-${localEnv:USER}${localEnv:USERNAME}",
    "--ipc=host",
    "--shm-size=8g"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python",
        "jupyter.notebookFileRoot": "/workspace/capacitylab"
      }
    }
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/capacitylab,type=bind",
  "workspaceFolder": "/workspace/capacitylab",
  "postCreateCommand": "bash -lc \"tr -d '\\r' < .devcontainer/post-create.sh | bash\"",
  "remoteUser": "root"
}